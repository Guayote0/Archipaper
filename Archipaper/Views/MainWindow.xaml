<Window x:Class="Archipaper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archipaper" Width="860" Height="760" MinWidth="740" MinHeight="600"
        Background="{StaticResource PaperBrush}" Foreground="{StaticResource InkBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="42,34">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="A R C H I P A P E R" FontSize="30" FontWeight="SemiBold"/>
      <TextBlock Text="Architecture for your desktop" FontSize="15" Opacity=".62" Margin="0,4,0,25"/>
      <TextBlock x:Name="MonitorText" FontSize="12" Opacity=".55" Margin="0,-18,0,20"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="IMAGE COLLECTION" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <TextBox x:Name="FolderText" Height="38" Padding="10,8" VerticalContentAlignment="Center"/>
          <Button Grid.Column="1" Content="CHOOSE FOLDER" Click="ChooseFolder_Click" Margin="10,0,0,0"/>
        </Grid>
        <TextBlock Text="Use high-resolution JPG, PNG, or BMP images. Portrait images are automatically matched to the portrait monitor."
                   TextWrapping="Wrap" Opacity=".62" Margin="0,7,0,26"/>

        <TextBlock Text="ROTATION" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
          <TextBlock Text="Change every" VerticalAlignment="Center" FontSize="15"/>
          <ComboBox x:Name="IntervalCombo" Grid.Column="1" Height="36" Padding="8">
            <ComboBoxItem Tag="15">15 minutes</ComboBoxItem>
            <ComboBoxItem Tag="30">30 minutes</ComboBoxItem>
            <ComboBoxItem Tag="60">1 hour</ComboBoxItem>
            <ComboBoxItem Tag="120">2 hours</ComboBoxItem>
            <ComboBoxItem Tag="360">6 hours</ComboBoxItem>
            <ComboBoxItem Tag="1440">Daily</ComboBoxItem>
          </ComboBox>
        </Grid>
        <CheckBox x:Name="AutomaticCheck" Content="Rotate wallpapers automatically"/>
        <CheckBox x:Name="DifferentCheck" Content="Use a different image on each monitor"/>
        <CheckBox x:Name="RecentCheck" Content="Avoid recently used images"/>
        <CheckBox x:Name="StartupCheck" Content="Start Archipaper with Windows" Margin="0,7,0,26"/>

        <Border BorderBrush="#22171717" BorderThickness="1" Padding="18" Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="ONLINE ARCHITECTURE COLLECTION" FontWeight="Bold" FontSize="12"/>
            <TextBlock Text="Discover freely licensed architecture images, then approve each one before Archipaper can use it. Source, contributor, and license information are preserved."
                       TextWrapping="Wrap" Opacity=".68" Margin="0,8,0,10"/>
            <TextBlock Text="CATEGORIES" FontWeight="SemiBold" FontSize="11" Opacity=".72" Margin="0,2,0,3"/>
            <WrapPanel Margin="0,0,0,8">
              <CheckBox x:Name="BuildingsCategory" Content="Buildings" Margin="0,4,18,4"/>
              <CheckBox x:Name="InteriorsCategory" Content="Interiors" Margin="0,4,18,4"/>
              <CheckBox x:Name="DetailsCategory" Content="Details" Margin="0,4,18,4"/>
              <CheckBox x:Name="DrawingsCategory" Content="Drawings" Margin="0,4,18,4"/>
              <CheckBox x:Name="ModelsCategory" Content="Models" Margin="0,4,18,4"/>
              <CheckBox x:Name="ParametricCategory" Content="Parametric Architecture" Margin="0,4,18,4"/>
            </WrapPanel>
            <TextBlock Text="PREFERRED ARCHITECTS" FontWeight="SemiBold" FontSize="11" Opacity=".72" Margin="0,4,0,3"/>
            <TextBox x:Name="ArchitectsText" Padding="8,6" TextWrapping="Wrap" ToolTip="Separate names with commas"/>
            <TextBlock Text="FEATURE MORE OFTEN" FontWeight="SemiBold" FontSize="11" Opacity=".72" Margin="0,9,0,3"/>
            <TextBox x:Name="BoostedArchitectsText" Padding="8,6" ToolTip="Separate names with commas" Margin="0,0,0,8"/>
            <Button x:Name="DiscoverButton" Content="DISCOVER NEW IMAGES" HorizontalAlignment="Left" Click="Discover_Click"/>
            <Border x:Name="ReviewPanel" Background="#0C171717" Padding="12" Margin="0,10,0,0" Visibility="Collapsed">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Border Height="215" Background="#18171717">
                  <Image x:Name="CandidateImage" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                  <TextBlock x:Name="CandidateTitle" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" MaxHeight="44"/>
                  <TextBlock x:Name="CandidateSubject" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                  <TextBlock x:Name="CandidateCredit" Opacity=".65" TextWrapping="Wrap" Margin="0,4,0,8" MaxHeight="38"/>
                  <TextBox x:Name="CandidateArchitectText" Padding="7,5" Margin="0,0,0,5"
                           ToolTip="Architect shown on the wallpaper"/>
                  <TextBox x:Name="CandidateProjectText" Padding="7,5" Margin="0,0,0,5"
                           ToolTip="Project name shown on the wallpaper"/>
                  <StackPanel Orientation="Horizontal">
                    <Button Content="APPROVE" Background="{StaticResource AccentBrush}" Click="Approve_Click"/>
                    <Button Content="SKIP" Click="Skip_Click"/>
                    <Button Content="REJECT" Click="Reject_Click"/>
                    <Button Content="SOURCE" Click="Source_Click"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
            <TextBlock x:Name="QueueStatus" Opacity=".62" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

        <Expander Header="APPROVED COLLECTION" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Expanded="Collection_Expanded">
          <Border BorderBrush="#22171717" BorderThickness="1" Padding="14" Margin="0,8,0,0">
            <Grid>
              <Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
              <ListBox x:Name="ApprovedList" MinHeight="90" MaxHeight="175" DisplayMemberPath="DisplayTitle"
                       SelectionChanged="ApprovedList_SelectionChanged"/>
              <Grid Grid.Row="1" Margin="0,9,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="ApprovedDetails" VerticalAlignment="Center" Opacity=".62" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                  <Button x:Name="FavoriteButton" Content="FAVORITE" Click="Favorite_Click" IsEnabled="False"/>
                  <Button x:Name="ApprovedSourceButton" Content="SOURCE" Click="ApprovedSource_Click" IsEnabled="False"/>
                  <Button x:Name="RemoveButton" Content="REMOVE" Click="Remove_Click" IsEnabled="False" Margin="0,4,0,4"/>
                </StackPanel>
              </Grid>
            </Grid>
          </Border>
        </Expander>

        <Expander Header="RECENT WALLPAPER HISTORY" FontWeight="Bold" FontSize="12" Margin="0,0,0,16" Expanded="History_Expanded">
          <Border BorderBrush="#22171717" BorderThickness="1" Padding="14" Margin="0,8,0,0">
            <ListBox x:Name="HistoryList" MinHeight="75" MaxHeight="160"/>
          </Border>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2" Margin="0,22,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity=".65" Text="Ready."/>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="SAVE" Click="Save_Click"/>
        <Button Content="CHANGE NOW" Background="{StaticResource AccentBrush}" Click="ChangeNow_Click" Margin="0,4,0,4"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
